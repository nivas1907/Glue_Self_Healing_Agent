
# $env:AWS_REGION = "ap-south-1"$
# $env:BEDROCK_MODEL_ID = "amazon.nova-2-lite-v1:0"

# AWS_REGION=ap-south-1
# BEDROCK_MODEL_ID=amazon.nova-2-lite-v1:0
# AWS_PROFILE=default


# Bedrock & Region#
AWS_REGION=ap-south-1
NOVA_MODEL_ID=apac.amazon.nova-lite-v1:0

# Agent runtime configuration
MAX_TOKENS=800
TEMPERATURE=0.2
APPLY_FIX_DEFAULT=no          # yes|no (default behavior when user just presses Enter)
DEFAULT_DPU=3                 # used if user accepts remediation and leaves DPU blank

# Optional: local AWS profile for boto3 (overrides default credential chain)
AWS_PROFILE=default

# Optional: Glue job name to prefill
